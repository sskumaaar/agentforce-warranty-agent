<?xml version="1.0" encoding="UTF-8"?>
<AiEvaluationDefinition xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Claim Approver review queue + approve/reject (EA-01 to EA-08). Mix of topic routing and behavior assertions.</description>
    <name>WC_Approver_ReviewQueue_Test</name>
    <subjectName>Electra_Claim_Reviewer</subjectName>
    <subjectType>AGENT</subjectType>
    <subjectVersion>v1</subjectVersion>
    <testCase>
        <expectation>
            <expectedValue>WC_Review_Pending_Claims</expectedValue>
            <name>topic_sequence_match</name>
        </expectation>
        <inputs>
            <utterance>Show me the pending warranty claims queue</utterance>
        </inputs>
        <number>0</number>
    </testCase>
    <testCase>
        <expectation>
            <expectedValue>WC_Review_Pending_Claims</expectedValue>
            <name>topic_sequence_match</name>
        </expectation>
        <inputs>
            <utterance>What claims need review right now?</utterance>
        </inputs>
        <number>1</number>
    </testCase>
    <testCase>
        <expectation>
            <expectedValue>WC_Review_Pending_Claims</expectedValue>
            <name>topic_sequence_match</name>
        </expectation>
        <inputs>
            <utterance>Show me the highest risk claims first</utterance>
        </inputs>
        <number>2</number>
    </testCase>
    <testCase>
        <expectation>
            <expectedValue>WC_Review_Pending_Claims</expectedValue>
            <name>topic_sequence_match</name>
        </expectation>
        <inputs>
            <utterance>Show me pending claims from Pune Electra Service Center</utterance>
        </inputs>
        <number>3</number>
    </testCase>
    <testCase>
        <expectation>
            <expectedValue>WC_Review_Pending_Claims</expectedValue>
            <name>topic_sequence_match</name>
        </expectation>
        <inputs>
            <utterance>Review claim WC-TEST-SEED-003</utterance>
        </inputs>
        <number>4</number>
    </testCase>
    <testCase>
        <expectation>
            <expectedValue>confirm before approving</expectedValue>
            <name>bot_response_rating</name>
        </expectation>
        <inputs>
            <utterance>Approve WC-TEST-SEED-002 — mileage matches repair order, low risk, standard motor claim</utterance>
        </inputs>
        <number>5</number>
    </testCase>
    <testCase>
        <expectation>
            <expectedValue>confirm before rejecting</expectedValue>
            <name>bot_response_rating</name>
        </expectation>
        <inputs>
            <utterance>Reject WC-TEST-SEED-006 — duplicate VIN pattern, same drive motor twice in 30 days, suspect fraud</utterance>
        </inputs>
        <number>6</number>
    </testCase>
    <testCase>
        <expectation>
            <expectedValue>prompt for reason</expectedValue>
            <name>bot_response_rating</name>
        </expectation>
        <inputs>
            <utterance>Approve WC-TEST-SEED-002</utterance>
        </inputs>
        <number>7</number>
    </testCase>
</AiEvaluationDefinition>
